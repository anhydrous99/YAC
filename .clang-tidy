Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-chained-comparison,
  -bugprone-unchecked-optional-access,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-do-while,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-type-vararg,
  google-explicit-constructor,
  google-readability-casting,
  google-readability-todo,
  misc-unused-using-decls,
  modernize-*,
  -modernize-use-trailing-return-type,
  readability-*,
  -readability-identifier-length

WarningsAsErrors: ''

HeaderFilterRegex: 'src/.*\.hpp|tests/.*\.cpp'

CheckOptions:
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  - key: readability-identifier-naming.MemberCase
    value: lower_case
  - key: readability-identifier-naming.ConstexprVariableCase
    value: CamelCase
  - key: readability-identifier-naming.ConstexprVariablePrefix
    value: 'k'
  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase
  - key: readability-identifier-naming.GlobalConstantCase
    value: CamelCase
  - key: readability-identifier-naming.GlobalConstantPrefix
    value: 'k'
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: '_'
  - key: readability-identifier-naming.PublicMemberSuffix
    value: ''
  - key: modernize-use-override.IgnoreDestructors
    value: true
  - key: bugprone-empty-catch.IgnoreCatchWithKeywords
    value: '@todo;@TODO;best-effort;Best-effort;Mock server;Test cancellation;Destructors must not propagate'
  - key: readability-identifier-naming.Macros
    value: 'TEST_CASE;SECTION;REQUIRE;REQUIRE_FALSE;CHECK;CHECK_FALSE;TEST_CASE_METHOD;METHOD_AS_TEST_CASE;REGISTER_TEST_CASE;FAIL;FAIL_CHECK;SUCCEED;SKIP;TEMPLATE_TEST_CASE;TEMPLATE_TEST_CASE_METHOD;TEMPLATE_PRODUCT_TEST_CASE;TEMPLATE_PRODUCT_TEST_CASE_METHOD;TEMPLATE_LIST_TEST_CASE;TEMPLATE_LIST_TEST_CASE_METHOD;DYNAMIC_SECTION;GIVEN;WHEN;THEN;AND_GIVEN;AND_WHEN;AND_THEN'
