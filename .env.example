# YAC Configuration Example
# Copy this file to .env and customize the values as needed
#
# Environment variables set in the shell will override values in this file
# This follows the 12-factor app methodology

# Provider Configuration
# The AI provider to use (e.g., openai, anthropic, etc.)
YAC_PROVIDER=openai

# Model to use with the provider
YAC_MODEL=gpt-4o-mini

# Base URL for the provider's API
YAC_BASE_URL=https://api.openai.com/v1/

# Temperature for generation (0.0 to 2.0)
YAC_TEMPERATURE=0.7

# System prompt to use for conversations
# Use quotes if the prompt contains spaces
YAC_SYSTEM_PROMPT="You are a helpful assistant."

# API Key Configuration
# Note: API keys should typically be set via environment variables for security
# The provider-specific API key environment variable (e.g., OPENAI_API_KEY)
OPENAI_API_KEY=your-api-key-here
